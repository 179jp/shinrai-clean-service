---
import { serviceSections } from '../helper/serviceSections';
import { company } from '../content/company';

const rawOptions = serviceSections.flatMap((section) => {
  if (section.group === 'special') return [];
  if ('items' in section) {
    if (section.id === 'aircon') return ['エアコン'];
    return section.items.map((item) => item.name.trim());
  }
  return [];
});

const requestOptions = Array.from(new Set(rawOptions.filter(Boolean)));

requestOptions.push('定期で依頼したい', 'その他');

const intentOptions = ['依頼したい', '見積りしたい', '相談したい'];
---

<div class="contact-overlay" id="contactOverlay" aria-hidden="true">
  <div
    class="contact-drawer"
    id="contactDrawerPanel"
    role="dialog"
    aria-modal="true"
    aria-label="お問い合わせフォーム"
    tabindex="-1"
  >
    <div class="contact-drawer__header">
      <div>
        <p class="eyebrow">Contact</p>
        <h3 class="contact-drawer__title" id="contactDrawerTitle">
          お問い合わせ
        </h3>
      </div>
      <button
        type="button"
        class="contact-drawer__close"
        id="contactDrawerClose"
        aria-label="フォームを閉じる"
      >
        ×
      </button>
    </div>
    <p class="contact-drawer__call-container">
      <span class="contact-drawer__call-label"
        >お急ぎの場合はお電話でご連絡ください</span
      >
      <a
        class="contact-drawer__call"
        id="contactDrawerCall"
        href={`tel:${company.phone}`}
      >
        電話で問い合わせる
      </a>
    </p>

    <!-- Step 1: 入力フォーム -->
    <form class="contact-form" id="contactForm">

      <label class="form-field">
        <span class="form-label">ご依頼</span>
        <select name="ご依頼" required>
          <option value="新規">新規</option>
          <option value="リピート">リピート</option>
        </select>
      </label>

      <label class="form-field">
        <span class="form-label">お問い合わせ内容</span>
        <select name="お問い合わせ内容" id="contactIntent" required>
          {
            intentOptions.map((option) => (
              <option value={option}>{option}</option>
            ))
          }
        </select>
      </label>

      <fieldset class="form-field">
        <legend class="form-label">ご依頼内容（複数選択可）</legend>
        <div class="request-options" role="group" aria-label="ご依頼内容">
          {
            requestOptions.map((option, index) => {
              const optionId = `request-${index}`;
              return (
                <label class="request-option" for={optionId}>
                  <input
                    type="checkbox"
                    id={optionId}
                    name="ご依頼内容"
                    value={option}
                    data-require-group={index === 0}
                  />
                  <span>{option}</span>
                </label>
              );
            })
          }
        </div>
      </fieldset>

      <div class="aircon-fields" id="airconFields" hidden>
        <label class="form-field">
          <span class="form-label">エアコン メーカー</span>
          <input
            type="text"
            name="エアコンメーカー"
            id="airconMaker"
            placeholder="例：ダイキン、三菱、パナソニック"
          />
        </label>
        <label class="form-field">
          <span class="form-label">エアコン 型番</span>
          <input
            type="text"
            name="エアコン型番"
            id="airconModel"
            placeholder="例：AN40YRS-W"
          />
        </label>
      </div>

      <label class="form-field">
        <span class="form-label">お名前</span>
        <input type="text" name="お名前" placeholder="山田 太郎" required />
      </label>

      <label class="form-field">
        <span class="form-label">電話番号</span>
        <input
          type="tel"
          name="電話番号"
          placeholder="090-1234-5678"
          required
        />
      </label>

      <label class="form-field">
        <span class="form-label">メールアドレス</span>
        <input
          type="email"
          name="メールアドレス"
          placeholder="example@example.com"
        />
      </label>

      <label class="form-field">
        <span class="form-label">コメント</span>
        <textarea
          name="コメント"
          rows="4"
          placeholder="ご要望やご相談内容をご記入ください"></textarea>
      </label>

      <button type="submit" class="contact-submit">確認する</button>
    </form>

    <!-- Step 2: 確認画面 -->
    <div class="contact-confirm" id="contactConfirm" hidden>
      <p class="contact-confirm__lead">以下の内容で送信します。</p>
      <dl class="contact-confirm__summary" id="contactConfirmSummary"></dl>
      <div class="contact-confirm__actions">
        <button type="button" class="contact-confirm__back" id="contactConfirmBack">
          修正する
        </button>
        <button type="button" class="contact-confirm__submit" id="contactConfirmSubmit">
          送信する
        </button>
      </div>
    </div>

    <!-- Step 3: 送信完了 -->
    <div class="contact-result" id="contactSuccess" hidden>
      <p class="contact-result__icon">✓</p>
      <p class="contact-result__title">送信しました</p>
      <p class="contact-result__body">お問い合わせありがとうございます。<br />内容を確認の上、ご連絡いたします。</p>
    </div>

    <!-- Step 3: エラー -->
    <div class="contact-result" id="contactError" hidden>
      <p class="contact-result__icon">!</p>
      <p class="contact-result__title">送信に失敗しました</p>
      <p class="contact-result__body">しばらく時間をおいて再度お試しください。<br />お急ぎの場合はお電話でご連絡ください。</p>
      <button type="button" class="contact-confirm__back" id="contactErrorBack">
        戻る
      </button>
    </div>
  </div>
</div>

<script>
  const contactOverlay = document.getElementById('contactOverlay');
  const contactDrawer = document.getElementById('contactDrawerPanel');
  const contactCloseButton = document.getElementById('contactDrawerClose');
  const contactTriggers = Array.from(
    document.querySelectorAll('[data-contact-trigger]')
  );
  const contactForm = document.getElementById('contactForm');
  const contactConfirm = document.getElementById('contactConfirm');
  const contactConfirmSummary = document.getElementById('contactConfirmSummary');
  const contactConfirmBack = document.getElementById('contactConfirmBack');
  const contactConfirmSubmit = document.getElementById('contactConfirmSubmit');
  const contactSuccess = document.getElementById('contactSuccess');
  const contactError = document.getElementById('contactError');
  const contactErrorBack = document.getElementById('contactErrorBack');
  const requestInputs = Array.from(
    document.querySelectorAll('input[name="ご依頼内容"]')
  );
  const airconCheckbox = requestInputs.find(
    (input) => input instanceof HTMLInputElement && input.value === 'エアコン'
  );
  const airconFields = document.getElementById('airconFields');
  let lastActiveElement = null;

  const SKIP_FIELDS = new Set(['form-name', 'bot-field']);

  const hideAll = () => {
    if (contactForm) contactForm.hidden = true;
    if (contactConfirm) contactConfirm.hidden = true;
    if (contactSuccess) contactSuccess.hidden = true;
    if (contactError) contactError.hidden = true;
  };

  const closeContactDrawer = () => {
    contactOverlay?.classList.remove('is-open');
    contactOverlay?.setAttribute('aria-hidden', 'true');
    document.body.classList.remove('no-scroll');
    document.body.classList.remove('drawer-open');
    if (lastActiveElement instanceof HTMLElement) {
      lastActiveElement.focus();
    }
  };

  const showForm = () => {
    hideAll();
    if (contactForm) contactForm.hidden = false;
    if (contactDrawer) contactDrawer.scrollTop = 0;
  };

  const showConfirm = () => {
    hideAll();
    if (contactConfirm) contactConfirm.hidden = false;
    if (contactDrawer) contactDrawer.scrollTop = 0;
  };

  const showSuccess = () => {
    hideAll();
    if (contactSuccess) contactSuccess.hidden = false;
    if (contactDrawer) contactDrawer.scrollTop = 0;
  };

  const showError = () => {
    hideAll();
    if (contactError) contactError.hidden = false;
    if (contactDrawer) contactDrawer.scrollTop = 0;
  };

  const buildSummary = () => {
    if (!contactForm || !contactConfirmSummary) return;

    const data = new FormData(contactForm);
    const grouped = new Map();

    for (const [key, value] of data.entries()) {
      if (SKIP_FIELDS.has(key) || !String(value).trim()) continue;
      if (grouped.has(key)) {
        grouped.get(key).push(String(value));
      } else {
        grouped.set(key, [String(value)]);
      }
    }

    contactConfirmSummary.innerHTML = '';
    for (const [key, values] of grouped) {
      const dt = document.createElement('dt');
      dt.className = 'contact-confirm__label';
      dt.textContent = key;

      const dd = document.createElement('dd');
      dd.className = 'contact-confirm__value';
      dd.textContent = values.join('、');

      contactConfirmSummary.appendChild(dt);
      contactConfirmSummary.appendChild(dd);
    }
  };

  const openContactDrawer = () => {
    lastActiveElement = document.activeElement;
    showForm();
    contactOverlay?.classList.add('is-open');
    contactOverlay?.setAttribute('aria-hidden', 'false');
    document.body.classList.add('no-scroll');
    document.body.classList.add('drawer-open');
    contactDrawer?.focus();
  };

  const updateAirconFields = () => {
    const isChecked =
      airconCheckbox instanceof HTMLInputElement
        ? airconCheckbox.checked
        : false;
    if (airconFields) airconFields.hidden = !isChecked;
  };

  const updateRequestRequirement = () => {
    const anyChecked = requestInputs.some(
      (input) => input instanceof HTMLInputElement && input.checked
    );
    requestInputs.forEach((input) => {
      if (
        input instanceof HTMLInputElement &&
        input.dataset.requireGroup === 'true'
      ) {
        input.required = !anyChecked;
      }
    });
  };

  contactForm?.addEventListener('submit', (event) => {
    event.preventDefault();
    buildSummary();
    showConfirm();
  });

  contactConfirmBack?.addEventListener('click', () => {
    showForm();
  });

  contactErrorBack?.addEventListener('click', () => {
    showConfirm();
  });

  contactConfirmSubmit?.addEventListener('click', async () => {
    if (!(contactForm instanceof HTMLFormElement)) return;

    contactConfirmSubmit.disabled = true;
    contactConfirmSubmit.textContent = '送信中…';

    const formData = new FormData(contactForm);
    const body: Record<string, string | string[]> = {};
    for (const [key, value] of formData.entries()) {
      if (SKIP_FIELDS.has(key) || !String(value).trim()) continue;
      const existing = body[key];
      if (existing) {
        body[key] = Array.isArray(existing)
          ? [...existing, String(value)]
          : [existing, String(value)];
      } else {
        body[key] = String(value);
      }
    }

    try {
      const res = await fetch('/.netlify/functions/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });
      if (res.ok) {
        showSuccess();
      } else {
        showError();
      }
    } catch {
      showError();
    } finally {
      contactConfirmSubmit.disabled = false;
      contactConfirmSubmit.textContent = '送信する';
    }
  });

  contactTriggers.forEach((trigger) => {
    trigger.addEventListener('click', (event) => {
      event.preventDefault();
      openContactDrawer();
    });
  });

  contactCloseButton?.addEventListener('click', () => {
    closeContactDrawer();
  });

  contactOverlay?.addEventListener('click', (event) => {
    if (event.target === contactOverlay) {
      closeContactDrawer();
    }
  });

  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') {
      closeContactDrawer();
    }
  });

  airconCheckbox?.addEventListener('change', () => {
    updateAirconFields();
    updateRequestRequirement();
  });

  requestInputs.forEach((input) => {
    if (input !== airconCheckbox) {
      input.addEventListener('change', updateRequestRequirement);
    }
  });

  updateRequestRequirement();
  updateAirconFields();
</script>
